{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/DiscordThreadSession",
  "definitions": {
    "DiscordThreadSession": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "status": {
          "$ref": "#/definitions/LifecycleStatus"
        },
        "trace": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "updatedAt": {
          "type": "string"
        },
        "guildId": {
          "type": "string"
        },
        "channelId": {
          "type": "string"
        },
        "parentChannelId": {
          "type": "string"
        },
        "threadId": {
          "type": "string"
        },
        "kind": {
          "$ref": "#/definitions/DiscordThreadKind"
        },
        "specId": {
          "type": [
            "string",
            "null"
          ]
        },
        "sliceId": {
          "type": [
            "string",
            "null"
          ]
        },
        "artifactId": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "summary",
        "status",
        "trace",
        "updatedAt",
        "guildId",
        "channelId",
        "parentChannelId",
        "threadId",
        "kind",
        "specId",
        "sliceId",
        "artifactId"
      ],
      "additionalProperties": false
    },
    "LifecycleStatus": {
      "type": "string",
      "enum": [
        "draft",
        "queued",
        "claimed",
        "running",
        "review",
        "blocked",
        "approved",
        "merge-ready",
        "merged",
        "failed",
        "rebasing",
        "complete"
      ]
    },
    "DiscordThreadKind": {
      "type": "string",
      "enum": [
        "spec",
        "implementation"
      ]
    }
  }
}
