{
  "name": "@vannadii/devplat-core",
  "version": "0.0.0",
  "description": "Shared domain primitives for DevPlat.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "schemas"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc -b tsconfig.json --pretty false",
    "test": "vitest run --dir src"
  },
  "dependencies": {
    "fp-ts": "2.16.11",
    "io-ts": "2.2.22"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/VannaDii/devplat.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/VannaDii/devplat/issues"
  },
  "homepage": "https://github.com/VannaDii/devplat#readme",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
